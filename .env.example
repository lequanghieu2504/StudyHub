# =========================================================================
# ROOT ENVIRONMENT VARIABLES TEMPLATE FOR STUDY HUB (SWP391 PROJECT)
# Copy this file to '.env' and fill in the required values.
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND CONFIGURATIONS
# -------------------------------------------------------------------------

# Server configuration
SERVER_PORT=8080

# Database Configuration (PostgreSQL or MySQL)
DB_URL=jdbc:postgresql://localhost:5432/your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# Spring Mail Configuration (For sending emails/OTPs)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_email_app_password

# Groq API Configuration (For Llama-3 AI generation: Ask, Quiz, Mindmap, Flashcards)
GROQ_API_KEY=your_groq_api_key

# Jina AI API Configuration (For generating embeddings in Vector Search/RAG)
JINA_API_KEY=your_jina_api_key

# Google OAuth2 Credentials (For backend Google Login verification)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary Configuration (For document/image upload storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS Configuration (Allowed origins, separated by comma)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATIONS
# -------------------------------------------------------------------------

# Frontend API URL pointing to the Backend server
VITE_API_URL=http://localhost:8080

# Google Client ID for OAuth2 login on the frontend
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
