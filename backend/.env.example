# =========================================================================
# BACKEND ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' in the same folder and fill in the values.
# =========================================================================

# Server Port
SERVER_PORT=8080

# Database Configuration (PostgreSQL/MySQL)
DB_URL=jdbc:postgresql://localhost:5432/your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# Spring Mail Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_email_app_password

# Groq API Key (AI Tools)
GROQ_API_KEY=your_groq_api_key

# Jina AI API Key (Vector Search / Embeddings / RAG)
JINA_API_KEY=your_jina_api_key

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary Configuration (Image/file uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS Allowed Origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
